---
import { whyAelionIntro, whyAelionItems } from "../../data/whyAelion";

const {
  kicker = whyAelionIntro.kicker,
  title = whyAelionIntro.title,
  items = whyAelionItems,
} = Astro.props;
---

<section>
  <div class="bg-white section-body pb-0 md:pb-0 min-[1536px]:pb-0">
    <div class="container-site">
      <div class="mb-6 h-1 w-14 bg-primary" aria-hidden="true"></div>

      <p class="text-xs font-medium uppercase tracking-[0.2em] text-navy min-[1536px]:text-sm">
        {kicker}
      </p>

      <h2
        class="mt-4 max-w-2xl text-3xl font-medium leading-tight tracking-tight text-gray md:text-4xl min-[1536px]:text-[40px] min-[1536px]:leading-[1.2]"
      >
        {title}
      </h2>
    </div>
  </div>

  <div class="bg-cream pt-12 pb-16 min-[1536px]:pt-16 min-[1536px]:pb-20">
    <div class="container-site why-cards-wrap">
      <div class="why-cards-grid">
        {
          items.map((item) => (
            <article
              class="why-card flex min-h-[280px] flex-col items-center border border-navy/10 bg-white px-5 py-8 text-center sm:px-6 sm:py-9 min-[1536px]:px-6 min-[1536px]:py-10"
            >
              <span
                class="text-6xl font-light leading-none text-transparent [-webkit-text-stroke:1.5px_#02af9f] md:text-7xl min-[1536px]:text-[5rem]"
              >
                {item.number}
              </span>

              <h3 class="mt-6 text-base font-medium leading-snug text-navy min-[1536px]:mt-7 min-[1536px]:text-[27px] min-[1536px]:leading-[1.25]">
                <span class="block">{item.title[0]}</span>
                <span class="block">{item.title[1]}</span>
              </h3>

              <p class="mt-4 text-sm leading-relaxed text-gray min-[1536px]:mt-5 min-[1536px]:text-[20px] min-[1536px]:leading-[1.5]">
                {item.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
