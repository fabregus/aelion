---
import { images } from "../../data/images";

const {
  id = "about",
  kicker = "WHO WE ARE",
  title = "AELION: A New Standard in Facility Management",
  body = "AELION is a premium facility management company delivering integrated soft and hard services across commercial, residential, hospitality, and institutional environments. We combine operational excellence with a boutique service philosophy, ensuring every property operates at peak performance — safely, efficiently, and flawlessly.",
  imageSrc = images.stock.alexanderTsang,
  imageAlt = "Modern commercial building facade",
  backgroundSrc = images.stock.maartenDeckers,
  backgroundSrc2x = images.stock.maartenDeckers2x,
} = Astro.props;
---

<section id={id} class="who">
  <div class="who__bg" aria-hidden="true">
    <picture>
      <source media="(min-width: 768px)" srcset={backgroundSrc2x} />
      <img
        src={backgroundSrc}
        alt=""
        class="h-full w-full object-cover object-left"
        loading="lazy"
        decoding="async"
      />
    </picture>
  </div>

  <div class="who__layout">
    <div class="who__panel">
      <div class="who__row">
        <div class="who__copy">
          <div class="who__line" aria-hidden="true"></div>
          <p class="who__kicker">{kicker}</p>
          <h2 class="who__title">{title}</h2>
          <p class="who__body">{body}</p>
        </div>

        <figure class="who__media">
          <img
            src={imageSrc}
            alt={imageAlt}
            class="absolute inset-0 h-full w-full object-cover object-center"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>
    </div>
  </div>
</section>

<style>
  .who {
    --who-gap: 64px;
    --who-panel-pl: 50px;
    --who-panel-py: 72px;
    --who-layout-pl: 107px;
    --who-top: 292px;
    --who-copy-w: 847px;
    --who-img: 580px;

    position: relative;
    overflow: visible;
    min-height: 720px;
  }

  .who__bg {
    position: absolute;
    inset: 0;
  }

  .who__layout {
    position: relative;
    z-index: 1;
    display: flex;
    min-height: inherit;
    flex-direction: column;
    justify-content: flex-end;
    padding: 160px 0 0;
    padding-left: 1.5rem;
  }

  .who__panel {
    overflow: hidden;
    background-color: var(--color-white);
    padding: 2.5rem 1.5rem;
  }

  .who__row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--who-gap);
  }

  .who__copy {
    width: 100%;
    max-width: 36rem;
  }

  .who__line {
    width: 3.5rem;
    height: 4px;
    margin-bottom: 1.5rem;
    background-color: var(--color-primary);
  }

  .who__kicker {
    margin: 0 0 16px;
    font-size: 0.6875rem;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .who__title {
    margin: 0 0 24px;
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-navy);
  }

  .who__body {
    margin: 0;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.65;
    color: var(--color-gray);
  }

  .who__media {
    position: relative;
    flex-shrink: 0;
    width: 100%;
    max-width: 28rem;
    aspect-ratio: 1;
  }

  .who__media img {
    display: block;
  }

  @media (min-width: 768px) {
    .who {
      min-height: 880px;
    }

    .who__layout {
      padding-top: 220px;
      padding-left: 2.5rem;
    }

    .who__panel {
      padding: 3rem 0 3rem 2rem;
    }

    .who__row {
      display: grid;
      width: 100%;
      grid-template-columns: minmax(0, 1fr) minmax(240px, 38vw);
      column-gap: var(--who-gap);
      align-items: center;
    }

    .who__copy {
      max-width: min(560px, 100%);
    }

    .who__title {
      font-size: 1.75rem;
    }

    .who__body {
      font-size: 1.0625rem;
      line-height: 1.7;
    }

    .who__media {
      width: 100%;
      max-width: none;
      justify-self: end;
    }
  }

  @media (min-width: 1024px) {
    .who {
      min-height: 1050px;
      --who-layout-pl: 90px;
    }

    .who__layout {
      padding-top: var(--who-top);
      padding-left: var(--who-layout-pl);
    }

    .who__panel {
      padding: var(--who-panel-py) 0 var(--who-panel-py) var(--who-panel-pl);
    }

    .who__row {
      grid-template-columns: minmax(0, 1fr) minmax(400px, 32vw);
    }

    .who__copy {
      max-width: min(720px, 100%);
    }

    .who__kicker {
      font-size: 0.75rem;
    }

    .who__title {
      font-size: 2rem;
      margin-bottom: 28px;
    }

    .who__body {
      font-size: 1.375rem;
      line-height: 2.125rem;
    }
  }

  /* 1920 artboard — fixed columns, 64px gap, no stretch between text & image */
  @media (min-width: 1800px) {
    .who {
      min-height: 1080px;
      --who-layout-pl: 107px;
    }

    .who__layout {
      padding-top: var(--who-top);
      padding-left: var(--who-layout-pl);
    }

    .who__panel {
      padding: var(--who-panel-py) 0 var(--who-panel-py) var(--who-panel-pl);
    }

    .who__row {
      grid-template-columns: var(--who-copy-w) var(--who-img);
      column-gap: var(--who-gap);
      width: 100%;
      max-width: none;
    }

    .who__copy {
      width: var(--who-copy-w);
      max-width: var(--who-copy-w);
    }

    .who__line {
      margin-bottom: 24px;
    }

    .who__kicker {
      margin-bottom: 20px;
      font-size: 14px;
      letter-spacing: 0.12em;
    }

    .who__title {
      margin-bottom: 32px;
      font-size: 40px;
      line-height: 1.25;
    }

    .who__body {
      font-size: 25px;
      line-height: 38px;
    }

    .who__media {
      width: var(--who-img);
      height: var(--who-img);
      aspect-ratio: 1;
      justify-self: start;
    }
  }
</style>
