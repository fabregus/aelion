---
import ServiceCategoryBand from "./ServiceCategoryBand.astro";
import {
  serviceCategories,
  servicesIntro,
} from "../../data/services";

const {
  kicker = servicesIntro.kicker,
  title = servicesIntro.title,
  intro = servicesIntro.text,
  categories = serviceCategories,
} = Astro.props;
---

<section id="solutions" class="bg-white">
  <div class="container-site">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-gray">
      {kicker}
    </p>
    <h2 class="mt-4 max-w-3xl text-3xl font-medium leading-tight tracking-tight text-navy md:text-4xl">
      {title}
    </h2>
    <p class="mt-6 max-w-3xl text-base leading-relaxed text-gray md:text-[17px]">
      {intro}
    </p>
  </div>

  {categories.map((cat) => <ServiceCategoryBand {...cat} />)}
</section>
