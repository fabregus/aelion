---
import Logo from "./Logo.astro";
import BluegameButton from "./BluegameButton.astro";

const defaultNav = [
  { href: "#about", label: "About Us" },
  { href: "#solutions", label: "Solutions" },
  { href: "#industries", label: "Industries" },
  { href: "#contact", label: "Contact" },
];
const { nav = defaultNav } = Astro.props;
---

<header class="absolute inset-x-0 top-0 z-50">
  <div class="container-site">
    <nav class="site-grid h-20 items-center md:h-24 lg:h-[7.5rem]">
      <!-- left: logo -->
      <div class="col-span-6 flex items-center lg:col-span-2">
        <Logo />
      </div>

      <!-- center: desktop nav -->
      <ul class="col-span-6 hidden items-center justify-center gap-16 text-white/90 lg:col-span-8 lg:flex">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="block text-sm font-semibold tracking-wide transition hover:text-white"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- right: Bluegame + mobile menu -->
      <div class="col-span-6 flex items-center justify-end gap-4 lg:col-span-2">
        <div class="hidden lg:block">
          <BluegameButton variant="header" />
        </div>

        <button
          class="inline-flex h-10 w-10 items-center justify-center text-white/90 transition hover:text-white lg:hidden"
          aria-label="Open menu"
          data-menu-open
        >
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M4 7h16M4 12h16M4 17h16"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"></path>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- mobile drawer -->
  <div class="fixed inset-0 z-50 hidden" data-menu-overlay aria-hidden="true">
    <div class="absolute inset-0 bg-black/50" data-menu-close></div>

    <div
      class="absolute right-0 top-0 h-full w-[88%] max-w-sm bg-dark p-6"
    >
      <div class="flex items-center justify-between">
        <Logo />
        <button
          class="inline-flex h-10 w-10 items-center justify-center text-white/90 transition hover:text-white"
          aria-label="Close menu"
          data-menu-close
        >
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M6 6l12 12M18 6L6 18"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"></path>
          </svg>
        </button>
      </div>

      <ul class="mt-10 space-y-6">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="block text-lg font-semibold text-white/90 transition hover:text-white"
                data-menu-link
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="mt-10">
        <BluegameButton variant="header" />
      </div>
    </div>
  </div>

  <script is:inline>
    const openBtn = document.querySelector("[data-menu-open]");
    const overlay = document.querySelector("[data-menu-overlay]");
    const closeEls = document.querySelectorAll("[data-menu-close]");
    const links = document.querySelectorAll("[data-menu-link]");

    function openMenu() {
      overlay?.classList.remove("hidden");
      document.documentElement.style.overflow = "hidden";
    }

    function closeMenu() {
      overlay?.classList.add("hidden");
      document.documentElement.style.overflow = "";
    }

    openBtn?.addEventListener("click", openMenu);
    closeEls?.forEach((el) => el.addEventListener("click", closeMenu));
    links?.forEach((a) => a.addEventListener("click", closeMenu));

    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeMenu();
    });
  </script>
</header>
