---
import { contact } from "../data/content";

const { phone, email, social } = contact;
---

<footer id="contact" class="bg-navy text-white">
  <div class="container-site section-body pb-16 md:pb-20">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3 lg:gap-16">
      <!-- Call us -->
      <div>
        <p class="text-sm font-medium tracking-wide text-primary">Call us</p>
        <a
          href={`tel:${phone.replace(/\s+/g, "")}`}
          class="mt-2 inline-block text-lg text-white/95 transition hover:text-white"
        >
          {phone}
        </a>
      </div>

      <!-- Email us -->
      <div>
        <p class="text-sm font-medium tracking-wide text-primary">Email us</p>
        <a
          href={`mailto:${email}`}
          class="mt-2 inline-block text-lg text-white/95 transition hover:text-white"
        >
          {email}
        </a>
      </div>

      <!-- Get Social -->
      <div>
        <p class="text-sm font-medium tracking-wide text-primary">Get Social</p>
        <div class="mt-4 flex items-center gap-5">
          {
            social.map((item) => (
              <a
                href={item.href}
                aria-label={item.label}
                target="_blank"
                rel="noopener"
                class="text-white/85 transition hover:text-primary"
              >
                {item.icon === "instagram" && (
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.8" />
                    <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8" />
                    <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" />
                  </svg>
                )}
                {item.icon === "facebook" && (
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M14 8.5h2.2V5.4C15.8 5.3 14.9 5.2 14 5.2c-2 0-3.4 1.2-3.4 3.5v1.9H8v3h2.6V21h3.1v-7.4h2.5l.4-3h-2.9V9c0-.4.3-.5.8-.5z" />
                  </svg>
                )}
                {item.icon === "youtube" && (
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M21.6 8.2a2.5 2.5 0 0 0-1.8-1.8C18.2 6 12 6 12 6s-6.2 0-7.8.4A2.5 2.5 0 0 0 2.4 8.2 26 26 0 0 0 2 12a26 26 0 0 0 .4 3.8 2.5 2.5 0 0 0 1.8 1.8C5.8 18 12 18 12 18s6.2 0 7.8-.4a2.5 2.5 0 0 0 1.8-1.8A26 26 0 0 0 22 12a26 26 0 0 0-.4-3.8zM10 15V9l5.2 3z" />
                  </svg>
                )}
                {item.icon === "linkedin" && (
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M6.94 8.5V19H3.8V8.5zM5.37 4a1.82 1.82 0 1 1 0 3.65 1.82 1.82 0 0 1 0-3.65zM9 8.5h3v1.43h.04A3.3 3.3 0 0 1 15 8.25c3.2 0 3.8 2.1 3.8 4.83V19h-3.14v-4.92c0-1.17 0-2.68-1.63-2.68s-1.88 1.27-1.88 2.6V19H9z" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</footer>
